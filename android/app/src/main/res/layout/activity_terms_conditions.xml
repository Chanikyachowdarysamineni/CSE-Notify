<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#11212D">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#6D28D9"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Terms of Service"
            app:titleTextColor="#FFFFFF"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="#FFFFFF"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:padding="20dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last Updated: January 28, 2026"
                android:textSize="12sp"
                android:textStyle="italic"
                android:textColor="#94A3B8"
                android:layout_marginBottom="24dp"/>

            <!-- 1. Acceptance of Terms -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Acceptance of Terms"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="By accessing and using CSE Hub mobile application (&#34;the App&#34;), you accept and agree to be bound by the terms and provision of this agreement. If you do not agree to these Terms of Service, please do not use the App.\n\nThis App is operated by the Computer Science and Engineering Department at VFSTR University (&#34;we,&#34; &#34;us,&#34; or &#34;our&#34;) for educational and administrative purposes."
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 2. Eligibility -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Eligibility"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The App is intended for:\n• Students enrolled in the CSE Department at VFSTR University\n• Faculty members of the CSE Department\n• Administrative staff (HOD, Dean)\n\nYou must be at least 18 years old to use this App. By using the App, you represent and warrant that you meet these eligibility requirements."
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 3. User Accounts -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. User Accounts"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Account Registration"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E2E8F0"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="To use certain features of the App, you must register for an account. You agree to:\n• Provide accurate, current, and complete information\n• Maintain and update your information\n• Keep your password confidential\n• Notify us immediately of unauthorized access"
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Account Responsibilities"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E2E8F0"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="You are responsible for all activities that occur under your account. The university reserves the right to suspend or terminate accounts that violate these terms."
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 4. Acceptable Use -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4. Acceptable Use"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="You agree to use the App only for lawful purposes and in accordance with these Terms. You agree NOT to:\n• Post false, misleading, or inappropriate content\n• Impersonate any person or entity\n• Harass, abuse, or harm other users\n• Upload viruses or malicious code\n• Attempt to gain unauthorized access to the App\n• Use the App for commercial purposes without permission\n• Scrape or collect user data without consent\n• Interfere with the proper functioning of the App"
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 5. User Roles and Permissions -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="5. User Roles and Permissions"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Students"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E2E8F0"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• View events, notifications, and files\n• Register for events\n• Download shared documents\n• Update profile information"
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Faculty, HOD, and Dean"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E2E8F0"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• All student permissions\n• Post announcements and notifications\n• Create and manage events\n• Upload and manage files\n• View event attendees\n• Manage gallery content"
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 6. Content Guidelines -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="6. Content Guidelines"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="User-Generated Content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E2E8F0"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Faculty members who post content (announcements, events, files) must ensure:\n• Content is relevant to academic purposes\n• Information is accurate and current\n• Content does not violate copyright laws\n• Material is appropriate for an educational setting"
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Content Ownership"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E2E8F0"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="You retain ownership of content you post. However, by posting content, you grant the university a non-exclusive, royalty-free license to use, display, and distribute that content within the App for educational purposes."
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 7. Intellectual Property -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="7. Intellectual Property"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The App and its original content, features, and functionality are owned by VFSTR University and are protected by international copyright, trademark, and other intellectual property laws.\n\nYou may not copy, modify, distribute, or reverse-engineer any part of the App without prior written permission."
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 8. Event Registration -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="8. Event Registration"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="When registering for events through the App:\n• Registration does not guarantee participation\n• Event organizers may cancel or modify events\n• You must attend registered events or cancel in advance\n• False registrations may result in account suspension"
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 9. File Sharing -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="9. File Sharing"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Files shared through the App must:\n• Be relevant to academic purposes\n• Not contain malware or harmful code\n• Not violate copyright or intellectual property rights\n• Be appropriate in size and format\n\nDownloaded files are for personal academic use only and should not be redistributed without permission."
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 10. Privacy and Data Protection -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="10. Privacy and Data Protection"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your use of the App is also governed by our Privacy Policy. We collect and process personal information as described in the Privacy Policy, which is incorporated into these Terms by reference."
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 11. Notifications -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="11. Notifications"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="By using the App, you consent to receive:\n• Push notifications about events and announcements\n• Email notifications for important updates\n• System notifications about account activities\n\nYou may opt-out of non-essential notifications in the app settings."
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 12. Disclaimers -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="12. Disclaimers"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="THE APP IS PROVIDED &#34;AS IS&#34; AND &#34;AS AVAILABLE&#34; WITHOUT WARRANTIES OF ANY KIND. We do not guarantee:\n• Uninterrupted or error-free operation\n• Accuracy of content posted by users\n• Availability of specific features\n• Compatibility with all devices"
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 13. Limitation of Liability -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="13. Limitation of Liability"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="To the maximum extent permitted by law, VFSTR University shall not be liable for:\n• Indirect, incidental, or consequential damages\n• Loss of data or academic information\n• Missed events due to technical issues\n• Actions of other users"
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 14. Modifications to Service -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="14. Modifications to Service"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="We reserve the right to:\n• Modify or discontinue features without notice\n• Update the App for security or performance\n• Change these Terms of Service at any time\n\nContinued use of the App after changes constitutes acceptance of the modified terms."
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 15. Termination -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="15. Termination"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="We may terminate or suspend your account immediately, without prior notice, if you:\n• Violate these Terms of Service\n• Engage in fraudulent activity\n• Graduate or leave the university\n• Request account deletion"
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 16. Governing Law -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="16. Governing Law"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="These Terms shall be governed by and construed in accordance with the laws of India. Any disputes arising from these Terms or use of the App shall be subject to the exclusive jurisdiction of courts in Guntur, Andhra Pradesh."
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- 17. Contact Information -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="17. Contact Information"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="For questions about these Terms of Service, please contact:\n• Email: vfstrcsevignan@gmail.com\n• Phone: +91 863 234 4402\n• Address: CSE Department, VFSTR University, Vadlamudi, Guntur, AP"
                android:textSize="14sp"
                android:textColor="#CBD5E1"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="32dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📄"
                    android:textSize="32sp"
                    android:textColor="#8B5CF6"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="By using CSE Hub, you agree to these terms"
                    android:textSize="14sp"
                    android:textColor="#94A3B8"
                    android:textStyle="italic"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
