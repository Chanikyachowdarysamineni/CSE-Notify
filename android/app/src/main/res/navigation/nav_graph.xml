<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_dashboard">

    <fragment
        android:id="@+id/navigation_dashboard"
        android:name="com.csehub.app.dashboard.ui.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <fragment
        android:id="@+id/navigation_notifications"
        android:name="com.csehub.app.notification.ui.NotificationListFragment"
        android:label="Notifications"
        tools:layout="@layout/fragment_notification_list" />

    <fragment
        android:id="@+id/navigation_events"
        android:name="com.csehub.app.event.ui.EventListFragment"
        android:label="Events"
        tools:layout="@layout/fragment_event_list" />

    <fragment
        android:id="@+id/navigation_timetable"
        android:name="com.csehub.app.timetable.ui.TimetableFragment"
        android:label="Timetable"
        tools:layout="@layout/fragment_timetable" />

    <fragment
        android:id="@+id/navigation_files"
        android:name="com.csehub.app.file.ui.FileListFragment"
        android:label="Files"
        tools:layout="@layout/fragment_file_list" />

    <fragment
        android:id="@+id/navigation_gallery"
        android:name="com.csehub.app.gallery.ui.GalleryFragment"
        android:label="Gallery"
        tools:layout="@layout/fragment_gallery" />

    <fragment
        android:id="@+id/navigation_profile"
        android:name="com.csehub.app.profile.ui.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/navigation_search_student"
        android:name="com.csehub.app.search.ui.SearchStudentFragment"
        android:label="Search Student"
        tools:layout="@layout/fragment_search_student" />

    <fragment
        android:id="@+id/navigation_admin"
        android:name="com.csehub.app.admin.ui.AdminFragment"
        android:label="Admin Panel"
        tools:layout="@layout/fragment_admin" />

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.csehub.app.settings.ui.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/navigation_about"
        android:name="com.csehub.app.settings.ui.AboutFragment"
        android:label="About"
        tools:layout="@layout/fragment_about" />

    <fragment
        android:id="@+id/navigation_help"
        android:name="com.csehub.app.settings.ui.HelpFragment"
        android:label="Help &amp; Support"
        tools:layout="@layout/fragment_help" />
</navigation>
