<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/android:windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Profile Photo -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profilePhoto"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_profile"
            app:civ_border_width="3dp"
            app:civ_border_color="?attr/colorPrimary"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/profileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/profileRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student"
            android:textColor="?attr/colorPrimary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_badge_primary"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"/>

        <!-- Details Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorSurfaceVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Unique ID Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Registration / Employee ID"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:id="@+id/detailId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="22CSE1A001"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="16dp" />

                <!-- Mobile Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mobile Number"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:id="@+id/detailMobile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+91 9876543210"
                    android:textSize="16sp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="16dp" />

                <!-- College Email Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="College Email"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:id="@+id/detailCollegeEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="student@csehub.edu"
                    android:textSize="16sp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="16dp" />

                <!-- Section Field -->
                <LinearLayout
                    android:id="@+id/sectionContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Section"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView
                        android:id="@+id/detailSection"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="N/A"
                        android:textSize="16sp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="16dp" />
                </LinearLayout>

                <!-- Date of Birth Field -->
                <LinearLayout
                    android:id="@+id/dobContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date of Birth"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView
                        android:id="@+id/detailDob"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="N/A"
                        android:textSize="16sp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="16dp" />
                </LinearLayout>

                <!-- Day Scholar / Hosteller Field -->
                <LinearLayout
                    android:id="@+id/scholarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView
                        android:id="@+id/detailScholar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="N/A"
                        android:textSize="16sp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="16dp" />
                </LinearLayout>

                <!-- CGPA Field (visible only to student) -->
                <LinearLayout
                    android:id="@+id/cgpaContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cumulative GPA (CGPA)"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView
                        android:id="@+id/detailCgpa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8.92"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Edit Profile trigger -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/editButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="32dp"
            android:text="Edit Contact Info"
            app:cornerRadius="8dp" />

        <!-- Settings trigger -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/settingsButton"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="16dp"
            android:text="Settings &amp; Preferences"
            app:cornerRadius="8dp" />

        <!-- Logout trigger -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/logoutButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="16dp"
            android:textColor="?attr/colorError"
            app:strokeColor="?attr/colorError"
            android:text="Log Out"
            app:cornerRadius="8dp" />

    </LinearLayout>
</ScrollView>
