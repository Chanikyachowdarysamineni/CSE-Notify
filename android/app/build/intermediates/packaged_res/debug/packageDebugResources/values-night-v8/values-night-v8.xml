    <color name="secondary">#80CBC4</color>
    <color name="secondary_container">#00695C</color>
    <color name="shimmer_base">#2A2A2A</color>
    <color name="shimmer_highlight">#3A3A3A</color>
    <color name="surface">#1E1E1E</color>
    <color name="surface_variant">#2A2A2A</color>
    <color name="tertiary">#FFE082</color>
