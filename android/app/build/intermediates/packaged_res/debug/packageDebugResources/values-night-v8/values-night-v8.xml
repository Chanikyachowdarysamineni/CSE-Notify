    <color name="error_container">#4E1C24</color>
    <color name="glass_black_low">#33000000</color>
    <color name="glass_white_low">#0DFFFFFF</color>
    <color name="glass_white_medium">#1DFFFFFF</color>
    <color name="on_background">#E3E3E3</color>
    <color name="on_primary">#1A237E</color>
    <color name="on_secondary">#004D40</color>
    <color name="on_surface">#E3E3E3</color>
    <color name="on_surface_variant">#AAAAAA</color>
    <color name="primary">#C5CAE9</color>
