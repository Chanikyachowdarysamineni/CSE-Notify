<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
	<shortcut
		android:shortcutId="view_timetable"
		android:enabled="true"
		android:icon="@drawable/ic_timetable"
		android:shortcutShortLabel="@string/shortcut_timetable_short"
		android:shortcutLongLabel="@string/shortcut_timetable_long">
		<intent
			android:action="android.intent.action.VIEW"
			android:targetPackage="com.vfstr.cse"
			android:targetClass="com.csehub.app.dashboard.ui.MainActivity">
			<extra android:name="navigate_to" android:value="timetable" />
		</intent>
	</shortcut>
	<shortcut
		android:shortcutId="view_notifications"
		android:enabled="true"
		android:icon="@drawable/ic_notification"
		android:shortcutShortLabel="@string/shortcut_notifications_short"
		android:shortcutLongLabel="@string/shortcut_notifications_long">
		<intent
			android:action="android.intent.action.VIEW"
			android:targetPackage="com.vfstr.cse"
			android:targetClass="com.csehub.app.dashboard.ui.MainActivity">
			<extra android:name="navigate_to" android:value="notifications" />
		</intent>
	</shortcut>
</shortcuts>
